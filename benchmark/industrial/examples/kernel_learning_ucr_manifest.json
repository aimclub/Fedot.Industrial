{
  "version": "benchmark_industrial_manifest@1",
  "kind": "suite",
  "task_type": "ts_classification",
  "datasets": [
    {
      "benchmark": "ucr",
      "dataset_name": "Lightning7"
    }
  ],
  "models": [
    {
      "adapter_name": "kernel_ensemble_classifier",
      "display_name": "KernelEnsembleClassifier",
      "params": {
        "generator_names": [
          "statistical_summary"
        ],
        "kernel": "linear",
        "C": 10.0
      }
    }
  ],
  "artifact_spec": {
    "output_dir": "benchmark/results/kernel_learning/ucr",
    "persist_on_run": true
  },
  "run_spec": {
    "run_name": "kernel_learning_ucr_lightning7",
    "primary_metric": "accuracy"
  },
  "metrics": [
    "accuracy",
    "balanced_accuracy",
    "f1_macro"
  ]
}
